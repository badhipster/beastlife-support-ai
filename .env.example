# --- AI (Google Gemini) ---
# Required for live classification, KB-grounded drafting, and KB embeddings.
# Without a valid key the app degrades to a keyword classifier + offline drafts.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- Database (Postgres + pgvector) ---
# Connection string to a Postgres database with the `vector` extension enabled
# (e.g. Supabase or Neon). Stores threads, drafts, escalations, KB embeddings, etc.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- App URL ---
# Where the app is hosted. Used for OAuth callbacks and self-referential links.
APP_URL="http://localhost:3000"

# --- Google OAuth (Gmail connect + app sign-in) ---
# One OAuth client serves both connecting the support inbox and app sign-in.
# Authorized redirect URI: ${APP_URL}/api/auth/google/callback
# Enable the Gmail API on the project; scopes: gmail.readonly, gmail.modify, gmail.send.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"
